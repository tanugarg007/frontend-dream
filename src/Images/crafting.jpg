	#collageSlider{
    /*background-image: url(../images/backgrounds/home-slider.webp);*/
    background-color:#1D1D1D;
	background-position: center;
	background-size: cover;
	background-attachment: fixed;
	background-repeat: no-repeat;
	background-origin: content-box;
	transition: all 0.3s ease cubic-bezier(0.25, 0.46, 0.45, 0.94);
	max-width: 100%;
	overflow: hidden;
}

        #home_collage {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            z-index: -2;
            padding: 0px;
            transition: all 0.4s ease-in-out !important;
        }

        #home_collage .video-container {
            position: relative;
            height: 600px;
            width: 100vw;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }

        #home_collage .video-container video {
            z-index: -3;
            position: absolute;
            width: auto;
            height: 100%;
            min-width: 100%;
            min-height: 100%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            object-fit: fill;
        }

        #home_collage .video-cover {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            background: rgba(0, 0, 0, 0.1);
        }

        .video-cover .col-6 figure .col-image {
            filter: opacity(0);
            transition: all 0.4s ease-in-out;
            cursor: pointer !important;
        }

     /*   .video-cover .col-6 figure:hover .col-image {
            filter: opacity(1);
            background: linear-gradient(90deg, rgba(128,128,255,1) 0%, rgba(255,0,0,0.8) 100%);
        }*/


        #vfx_block .blur {
            background: url('dist/images/home/vfx-back.jpg');
        }

        #animation_block .blur{
            background-image: url('dist/images/home/animation-blur.jpg');
        }
        
        #maya_block .blur{
            background-image: url('dist/images/home/maya-blur.jpg');
        }

        #graphicsweb_block .blur{
            background-image: url('dist/images/home/webgrap-blur.jpg');
        }

        #gametesting_block .blur{
            background-image: url('dist/images/home/game-testing.jpg');
        }

        #filmmaking_block .blur{
            background-image: url('dist/images/home/filmmake-blur.jpg');
        }

        #vfx_block, 
        #animation_block, 
        #maya_block, 
        #gametesting_block, 
        #graphicsweb_block, 
        #filmmaking_block {
            background-size: cover;
            background-attachment: fixed;
            background-position: center;
            background-repeat: no-repeat;
            height: 100% !important;
            transition: all 1s ease-in-out !important;
        }

        #vfx_block .d-flex, 
        #animation_block .d-flex, 
        #maya_block .d-flex, 
        #gametesting_block .d-flex, 
        #graphicsweb_block .d-flex, 
        #filmmaking_block .d-flex{
            background: linear-gradient(35deg, rgba(18,18,143,0.95) 0%, rgba(255,0,224,0.95) 100%);
        }
        
    /*    #vfx_block .d-flex:hover, 
        #animation_block .d-flex:hover, 
        #maya_block .d-flex:hover, 
        #gametesting_block .d-flex:hover, 
        #graphicsweb_block .d-flex:hover, 
        #filmmaking_block .d-flex:hover{
            background: linear-gradient(35deg, rgba(255,0,224,0.95) 0%, rgba(18,18,143,0.95) 100%);
        }*/

        #vfx_home_info, 
        #animation_home_info,
        #maya_home_info,
        #gaming_home_info,
        #graphicsweb_home_info,
        #filmmaking_home_info {
            background-color: rgba(0,0,0,0.95);
        }
        
        [id$="_home_info"] h1 {
            font-size: 40pt !important; 
            font-weight: 500;
        }

        [id$="_home_info"] p {
            font-size: 13pt !important; 
            font-weight: 300;
        }

        .blur {
            background-position: center !important;
            background-size: cover !important;
            background-attachment: fixed !important;
            overflow: hidden;
            filter: blur(1px);
            box-shadow: inset 0px 0px 16px rgba(0, 0, 0, 0.25);
            height: 100%;
            position: absolute;
            width: 100%;
            top: 0;
            left: 0;
            z-index: -2;
        }

        /* ============ STEPS BACKGROUND ============= */
        #tab_bg {
           background: rgb(242,11,35);
           background: linear-gradient(90deg, rgba(242,11,35,1) 0%, rgba(35,17,235,1) 100%, rgba(233,13,58,1) 100%);
           /* background-image: url('dist/images/backgrounds/agra_org.jpg');*/
            background-size: cover;
            background-attachment: fixed;
            background-position: center;
            background-repeat: no-repeat;
            height: 100%;
        }
       /*   .card:hover{
			background-color: #2479d3;
		}*/
        #steps_block #steps_home_info {
            background-color: rgba(0,0,0,0.75);
        }

        #steps_block #steps_home_info  h1 {
            font-size: 36pt;            
        }

        #steps_block #steps_home_info  p {
            font-size: 16pt;            
        }

        .btn {
            transition: all 0.4s ease-in-out !important;
        }

        .d-flex {
            overflow: hidden !important;
        }
         @media only screen and (min-width: 300px) and (max-width: 900px) {
            html,body{
                width: 100%;
                height: 100vh;
                margin: 0px;
                padding: 0px;
                overflow-x: hidden;
            }
            #homeBanner{
                margin: 0;
                padding: 0;
                width: 100%;
                height: 200px;
            }
            
            #home_collage .video-container {
                height: 480px !important;
                width: 100% !important;
            }
        }
        @media only screen and (min-width: 500px) and (max-width: 600px) {
            #home_collage .video-container {
                height: 320px !important;
                width: 100% !important;
            }
        }

        @media only screen and (min-width: 600px) and (max-width: 900px) {
            #home_collage .video-container {
                height: 480px !important;
                width: 100% !important;
            }
        }

        @media only screen and (min-width: 1200px) and (max-width: 1500px) {
            #home_collage .video-container {
                height: 580px !important;
            }

            #home_collage .row:nth-child(2){
                height: 100% !important; 
            }

            .sec_desc {
                font-size: 12pt !important;
            }
        }

        @media only screen and (min-width: 1500px) and (max-width: 1700px) {
            #home_collage .video-container {
                height: 720px !important;
            }
        }

        @media only screen and (min-width: 1700px) and (max-width: 2000px) {
            #home_collage .video-container {
                height: 960px !important;
            }
        }

        @media screen and (max-width: 992px) {
            .video-cover .col-6 figure h1 {
                font-size: 24pt !important;
            }
            
            /* ==============================
                VFX - Special Effects
            ============================== */
            
            #vfx_block .sec_desc {
                font-size: 11pt !important;
                text-align: center !important;
                margin-bottom: 1rem !important;
            }
            
            #vfx_block .sec_desc p:first-child {
                display: none;
            }
            
            #vfx_block .row .col-12:last-child .d-flex {
                padding: 2rem 1.5rem !important;
            }
            
            #vfx_block .row .col-12:last-child h1 {
                font-size: 26pt !important; 
                text-align: center;
            }
            
            #vfx_block .row .col-12:last-child h1 .divider {
                margin: 0 auto !important;
                margin-bottom: 1rem !important;
            }
            
            #vfx_block .row .col-12:last-child .btn {
                width: 50% !important;
                margin: 0 auto !important;
            }
            
            #vfx_block .col-12:first-child .col-image{
                height: 320px !important;
            }
            
            /* ==============================
                Animation
            ============================== */
            
            #animation_block .sec_desc {
                font-size: 11pt !important;
                text-align: center !important;
                margin-bottom: 1rem !important;
            }
            
            #animation_block .sec_desc p:first-child {
                display: none;
            }
            
